//#prelude
import core:{runtime}

//#entry(check) "address_ref_const"
//#expect
//error: cannot get & to a constant, you can use global variable instead
//  │
//3 │     &CONSTANT;
//  │     ^^^^^^^^^
//  ├─ src/test.rock:3:5
//  │
//1 │ CONSTANT: s32 = 10;
//  │ ──────── constant defined here
//  └─ src/test.rock:1:1
//
//#!
CONSTANT: s32 = 10;
proc test_address_const() void {
    &CONSTANT;
}

//#entry(check) "address_slice_field"
//#expect
//error: cannot get & to a slice field
//  │
//2 │     &slice.ptr;
//  │     ^^^^^^^^^^
//  └─ src/test.rock:2:5
//
//error: cannot get &mut to a slice field
//  │
//3 │     &mut slice.len;
//  │     ^^^^^^^^^^^^^^
//  └─ src/test.rock:3:5
//
//#!
proc test_address_slice_field(slice: []u8) void {
    &slice.ptr;
    &mut slice.len;
}

//#entry "reference_void_proc_call"
proc test_reference_void_proc_call() void {
    let addr = &returns_void();
    runtime.assert(addr == null);
}

proc returns_void() void {}

//#entry "variadic_void_proc_call"
proc test_variadic_void_proc_call() void {
    take_variadic_void(returns_void_2());
}

proc take_variadic_void(args: #variadic) void {
    runtime.assert(args.len == 1);
    runtime.assert(args[0].data == null);
}

proc returns_void_2() void {}
