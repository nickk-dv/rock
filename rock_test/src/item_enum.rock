//#prelude
import core:mem;
import core:math;
import core:runtime as _.{assert}

//#entry(check) "enum_valid_tag_types"
enum Valid_S8 s8 {}
enum Valid_S16 s16 {}
enum Valid_S32 s32 {}
enum Valid_S64 s64 {}

enum Valid_U8 u8 {}
enum Valid_U16 u16 {}
enum Valid_U32 u32 {}
enum Valid_U64 u64 {}

