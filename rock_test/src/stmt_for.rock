//#prelude
import core:fmt.{print}
import core:runtime.{unreachable}

//#entry "for_loop"
//#expect(no_endl)
//123456789
//#!
proc test_for_loop() void {
    let mut idx = 0;
    for {
        idx += 1;
        print(idx);
        if idx == 9 {
            break;
        }
    }
}

//#entry "for_condition"
//#expect(no_endl)
//123456789
//123456789
//123456789
//123456789
//#!
proc test_for_condition() void {
    let mut idx = 0;
    for idx < 9 {
        idx += 1;
        print(idx);
    }
    idx = 0;
    print('\n');
    for (idx < 9) as bool16 {
        idx += 1;
        print(idx);
    }
    idx = 0;
    print('\n');
    for (idx < 9) as bool32 {
        idx += 1;
        print(idx);
    }
    idx = 0;
    print('\n');
    for (idx < 9) as bool64 {
        idx += 1;
        print(idx);
    }
}

//#entry "for_range"
//#expect(no_endl)
//0
//12345678
//123456789
//#!
proc test_for_range() void {
    for _ in 0..<0 {
        unreachable();
    }
    for idx in 0..=0 {
        print(idx);
    }
    print('\n');
    for idx in 1..<9 {
        print(idx);
    }
    print('\n');
    for idx in 1..=9 {
        print(idx);
    }
}

//#entry "for_loop_diverges"
//#expect(no_endl)
//thread panicked at src/test.rock:3:9
//entered unreachable code
//#!
proc test_for_loop_diverges() void {
    for {
        unreachable();
    }
    print("unreachable");
}

//#entry "for_cond_diverges"
//#expect(no_endl)
//thread panicked at src/test.rock:4:9
//entered unreachable code
//#!
proc test_for_cond_diverges() void {
    let value = true;
    for value {
        unreachable();
    }
    print("unreachable");
}

//#entry "for_element_diverges"
//#expect(no_endl)
//thread panicked at src/test.rock:3:9
//entered unreachable code
//#!
proc test_for_element_diverges() void {
    for _ in [10, 20, 30] {
        unreachable();
    }
    print("unreachable");
}

//#entry "for_range_diverges"
//#expect(no_endl)
//thread panicked at src/test.rock:3:9
//entered unreachable code
//#!
proc test_for_range_diverges() void {
    for _ in 0..<10 {
        unreachable();
    }
    print("unreachable");
}

//#entry "for_pattern_diverges"
//#expect(no_endl)
//thread panicked at src/test.rock:4:9
//entered unreachable code
//#!
proc test_for_pattern_diverges() void {
    let value = 0;
    for let 0 = value {
        unreachable();
    }
    print("unreachable");
}

//#entry "for_element"
//#expect(no_endl)
//10 0
//20 1
//30 2
//#!
proc test_for_element() void {
    let values = [10, 20, 30];
    for value, index in values {
        print(value, " ", index, "\n");
    }
}

//#entry "for_element_reverse"
//#expect(no_endl)
//30 2
//20 1
//10 0
//#!
proc test_for_element_reverse() void {
    let values = [10, 20, 30];
    for value, index in << values {
        print(value, " ", index, "\n");
    }
}

//#entry "for_element_continue"
//#expect(no_endl)
//10 0
//20 1
//30 2
//#!
proc test_for_element_continue() void {
    let values = [10, 20, 30];
    for value, index in values {
        print(value, " ", index, "\n");
        continue;
    }
}

//#entry "for_element_reverse_continue"
//#expect(no_endl)
//30 2
//20 1
//10 0
//#!
proc test_for_element_reverse_continue() void {
    let values = [10, 20, 30];
    for value, index in << values {
        print(value, " ", index, "\n");
        continue;
    }
}
